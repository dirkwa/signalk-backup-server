{
  "name": "signalk-backup-server",
  "version": "0.1.0",
  "description": "Headless backup engine for the signalk-backup plugin: Kopia-based deduplicated snapshots with optional rclone sync to Google Drive",
  "main": "dist/server.js",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "build:all": "npm run lint && npm run build && npm run test",
    "start": "node dist/server.js",
    "lint": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --fix --max-warnings 0",
    "format": "prettier --write \"src/**/*.{ts,tsx,js,jsx,json,css}\" \"README.md\" && npm run lint:fix",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,js,jsx,json,css}\" \"README.md\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@sinclair/typebox": "^0.34.30",
    "archiver": "^8.0.0",
    "better-sse": "^0.16.1",
    "cors": "^2.8.5",
    "express": "^4.21.2",
    "multer": "^2.0.2",
    "pino": "^9.6.0",
    "pino-http": "^10.3.0",
    "swagger-ui-express": "^5.0.1",
    "tar": "^7.4.3",
    "unzip-stream": "^0.3.4",
    "ws": "^8.18.0",
    "xstate": "^5.31.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.0",
    "@types/multer": "^2.0.0",
    "@types/node": "^22.10.5",
    "@types/swagger-ui-express": "^4.1.8",
    "@types/tar": "^7.0.87",
    "@types/unzip-stream": "^0.3.4",
    "@types/ws": "^8.5.13",
    "@vitest/coverage-v8": "^2.1.8",
    "eslint": "^10.3.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.2.1",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.4.2",
    "tsx": "^4.19.2",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.18.2",
    "vitest": "^2.1.8"
  },
  "engines": {
    "node": ">=22.5.0"
  },
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/dirkwa/signalk-backup-server.git"
  }
}
